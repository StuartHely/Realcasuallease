DATABASE_URL=postgresql://postgres:password@localhost:5432/casuallease
BASE_URL=http://localhost:3000
JWT_SECRET=your-super-secret-key-change-this-in-production
COOKIE_NAME=casuallease_session
SESSION_SECRET=another-secret-key-for-sessions-change-in-production
NODE_ENV=development

# Google Maps — set ONE of the two approaches:
# Option 1: Direct Google Maps API key (simplest)
VITE_GOOGLE_MAPS_API_KEY=

# Option 2: Forge proxy (used in production)
# VITE_FRONTEND_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
